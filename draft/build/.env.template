# Stonecutter — Environment Variables
# Copy this to ~/.env and fill in your values.
# Source: Bitwarden "Dev Keys" vault (shared keys) + personal credentials.
#
# This file is sourced by your shell (~/.zshrc or PowerShell profile).
# NEVER commit this file to git.

# ============================================================
# SHARED KEYS (same for everyone — copy from Bitwarden)
# ============================================================

# Slack bot (nanoclaw) — for posting/reading messages via curl
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# Amazon product data APIs
RAINFOREST_API_KEY=
KEEPA_API_KEY=

# Web search & scraping
BRAVE_API_KEY=
APIFY_API_KEY=

# AI-powered search
PERPLEXITY_API_KEY=

# Google Sheets service account (path to JSON key file)
GOOGLE_SHEETS_KEY_PATH=

# Google Workspace CLI (gws) — GCP project credentials
GOOGLE_WORKSPACE_CLI_CLIENT_ID=
GOOGLE_WORKSPACE_CLI_CLIENT_SECRET=

# ClickUp — direct API access (backup to Anthropic proxy)
CLICKUP_API_KEY=
CLICKUP_TEAM_ID=

# ============================================================
# PERSONAL KEYS (unique per person)
# ============================================================

# Claude Code billing — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# SQL Server — Pedro creates your account
SQL_SERVER=152.53.146.201
SQL_DATABASE=stonecutter
SQL_USERNAME=
SQL_PASSWORD=

# ============================================================
# NOTE: These are NOT needed in ~/.env (handled by CLI auth):
# - GitHub: `gh auth login` stores its own token
# - Google (Drive/Gmail/Calendar): `gws auth login` stores its own token
# - ClickUp (in Claude): Anthropic proxy handles OAuth
# ============================================================
